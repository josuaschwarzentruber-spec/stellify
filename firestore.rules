rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - firstName: string (required)
    //   - role: string (user, admin, schueler)
    //   - createdAt: timestamp
    //
    // Collection: users/{userId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - role: string (user, ai)
    //   - content: string (required)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "weare2bc@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'firstName']) &&
             data.uid is string &&
             (data.email is string || data.email == null) &&
             data.firstName is string &&
             data.firstName.size() < 100 &&
             (!('cvContext' in data) || data.cvContext is string || data.cvContext == null) &&
             (!('freeGenerationsUsed' in data) || data.freeGenerationsUsed is int) &&
             (!('role' in data) || data.role in ['client', 'admin', 'pro', 'unlimited']) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content', 'createdAt']) &&
             data.role in ['user', 'ai'] &&
             data.content is string &&
             data.content.size() < 50000 &&
             data.createdAt is timestamp;
    }

    function isValidToolResult(data) {
      return data.keys().hasAll(['toolId', 'toolTitle', 'input', 'result', 'createdAt']) &&
             data.toolId is string &&
             data.toolId.size() < 100 &&
             data.toolTitle is string &&
             data.toolTitle.size() < 200 &&
             data.input is map &&
             data.result is string &&
             data.result.size() < 100000 &&
             data.createdAt is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid;

      match /messages/{messageId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidMessage(request.resource.data);
      }

      match /toolResults/{resultId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidToolResult(request.resource.data);
      }
    }
  }
}
