rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - firstName: string (required)
    //   - role: string (user, admin, schueler)
    //   - createdAt: timestamp
    //
    // Collection: users/{userId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - role: string (user, ai)
    //   - content: string (required)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "weare2bc@gmail.com"));
    }

    function isValidUser(data) {
      return (!('uid' in data) || data.uid is string) &&
             (!('email' in data) || data.email is string || data.email == null) &&
             (!('firstName' in data) || (data.firstName is string && data.firstName.size() < 100)) &&
             (!('cvContext' in data) || data.cvContext is string || data.cvContext == null) &&
             (!('freeGenerationsUsed' in data) || data.freeGenerationsUsed is int) &&
             (!('role' in data) || data.role in ['client', 'admin', 'pro', 'unlimited']) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isRoleUnchanged(data, resourceData) {
      return !('role' in data) || data.role == resourceData.role;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content', 'createdAt']) &&
             data.role in ['user', 'ai'] &&
             data.content is string &&
             data.content.size() < 50000 &&
             data.createdAt is timestamp;
    }

    function isValidToolResult(data) {
      return data.keys().hasAll(['toolId', 'toolTitle', 'input', 'result', 'createdAt']) &&
             data.toolId is string &&
             data.toolId.size() < 100 &&
             data.toolTitle is string &&
             data.toolTitle.size() < 200 &&
             (data.input is map || data.input is string) &&
             data.result is string &&
             data.result.size() < 100000 &&
             data.createdAt is timestamp;
    }

    function isValidApplication(data) {
      return data.keys().hasAll(['company', 'position', 'status', 'createdAt']) &&
             data.company is string && data.company.size() < 200 &&
             data.position is string && data.position.size() < 200 &&
             data.status in ['Applied', 'Interview', 'Offer', 'Rejected', 'Wishlist'] &&
             (!('salary' in data) || data.salary is string || data.salary == null) &&
             (!('location' in data) || data.location is string || data.location == null) &&
             (!('notes' in data) || data.notes is string || data.notes == null) &&
             data.createdAt is timestamp &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidCVAnalysis(data) {
      return data.keys().hasAll(['keywords', 'industryMatch', 'improvements', 'score', 'createdAt']) &&
             data.keywords is list &&
             data.industryMatch is string &&
             data.improvements is list &&
             data.score is int &&
             data.createdAt is timestamp;
    }

    function isValidSalaryCalculation(data) {
      return data.keys().hasAll(['jobTitle', 'industry', 'experience', 'canton', 'minSalary', 'maxSalary', 'medianSalary', 'createdAt']) &&
             data.jobTitle is string &&
             data.industry is string &&
             data.experience is string &&
             data.canton is string &&
             data.minSalary is number &&
             data.maxSalary is number &&
             data.medianSalary is number &&
             (!('insights' in data) || data.insights is list) &&
             data.createdAt is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.keys().hasAll(['uid', 'firstName']) &&
                    (request.resource.data.role == 'client' || isAdmin());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                    (!('uid' in resource.data) || request.resource.data.uid == resource.data.uid) &&
                    (isRoleUnchanged(request.resource.data, resource.data) || isAdmin());

      match /messages/{messageId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidMessage(request.resource.data);
      }

      match /toolResults/{resultId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidToolResult(request.resource.data);
      }

      match /applications/{applicationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidApplication(request.resource.data);
        allow update: if isOwner(userId) && isValidApplication(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /cv_analyses/{analysisId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidCVAnalysis(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /salary_calculations/{calcId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidSalaryCalculation(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
