{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user account information and career preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "schueler"], "description": "User role for pricing plans" },
        "createdAt": { "type": "string", "format": "date-time" },
        "cvContext": { "type": "string", "description": "Extracted CV text context" },
        "freeGenerationsUsed": { "type": "integer", "description": "Number of free generations used" }
      },
      "required": ["uid", "email", "firstName"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in the conversation history.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "ai"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "createdAt"]
    },
    "CVAnalysis": {
      "title": "CV Analysis",
      "description": "AI-driven analysis of a user's CV.",
      "type": "object",
      "properties": {
        "keywords": { "type": "array", "items": { "type": "string" } },
        "industryMatch": { "type": "string" },
        "improvements": { "type": "array", "items": { "type": "string" } },
        "score": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["keywords", "industryMatch", "improvements", "score", "createdAt"]
    },
    "Application": {
      "title": "Job Application",
      "description": "A job application tracked by the user.",
      "type": "object",
      "properties": {
        "company": { "type": "string" },
        "position": { "type": "string" },
        "status": { "type": "string", "enum": ["Applied", "Interview", "Offer", "Rejected", "Wishlist"] },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "salary": { "type": "string" },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["company", "position", "status", "createdAt"]
    },
    "SalaryCalculation": {
      "title": "Salary Calculation",
      "description": "AI-estimated salary range and market insights.",
      "type": "object",
      "properties": {
        "jobTitle": { "type": "string" },
        "industry": { "type": "string" },
        "experience": { "type": "string" },
        "canton": { "type": "string" },
        "minSalary": { "type": "number" },
        "maxSalary": { "type": "number" },
        "medianSalary": { "type": "number" },
        "insights": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["jobTitle", "industry", "experience", "canton", "minSalary", "maxSalary", "medianSalary", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Conversation history subcollection"
    },
    "/users/{userId}/applications/{applicationId}": {
      "schema": "Application",
      "description": "Job applications subcollection"
    },
    "/users/{userId}/cv_analyses/{analysisId}": {
      "schema": "CVAnalysis",
      "description": "CV analyses subcollection"
    },
    "/users/{userId}/salary_calculations/{calcId}": {
      "schema": "SalaryCalculation",
      "description": "Salary calculations subcollection"
    }
  }
}
